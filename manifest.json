    "shortcuts": [
        {
            "name": "Phát hiện nhanh",
            "short_name": "Phát hiện",
            "description": "Bật camera và bắt đầu phát hiện rác thải",
            "url": "/?action=detect",
            "icons": [
                {
                    "src": "icons/shortcut-detect.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "ML Dashboard",
            "short_name": "ML",
            "description": "Xem thống kê và quản lý mô hình AI",
            "url": "/?tab=ml-dashboard",
            "icons": [
                {
                    "src": "icons/shortcut-ml.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Thống kê",
            "short_name": "Stats",
            "description": "Xem thống kê phân loại rác thải",
            "url": "/?tab=statistics",
            "icons": [
                {
                    "src": "icons/shortcut-stats.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Cài đặt",
            "short_name": "Settings",
            "description": "Cấu hình ứng dụng và mô hình AI",
            "url": "/?tab=settings",
            "icons": [
                {
                    "src": "icons/shortcut-settings.png",
                    "sizes": "96x96"
                }
            ]
        }
    ],
    "related_applications": [],
    "prefer_related_applications": false,
    "protocol_handlers": [
        {
            "protocol": "web+ecosort",
            "url": "/?action=%s"
        }
    ],
    "file_handlers": [
        {
            "action": "/",
            "accept": {
                "image/*": [".jpg", ".jpeg", ".png", ".gif", ".webp"]
            }
        }
    ],
    "share_target": {
        "action": "/",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "image",
                    "accept": ["image/*"]
                }
            ]
        }
    },
    "permissions": [
        "camera",
        "storage",
        "background-sync",
        "periodic-background-sync",
        "push",
        "notifications"
    ],
    "features": [
        "machine-learning",
        "computer-vision",
        "offline-support",
        "background-sync",
        "push-notifications"
    ]
}
